# Published Google Sheet CSV URL.
# In Google Sheets: File → Share → Publish to web → (sheet) → CSV → copy the URL.
# Must be PUBLIC_-prefixed so Astro exposes it to the client (the URL is public anyway).
PUBLIC_STICKER_CSV_URL=

# Google Form URL for the "Submit your sighting" button (optional).
PUBLIC_STICKER_FORM_URL=
